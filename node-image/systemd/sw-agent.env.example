# SecondWind node agent runtime config.
# Packaged node images should install this as /etc/secondwind/sw-agent.env.

# Optional display name shown during discovery/pairing.
SECONDWIND_AGENT_NODE_NAME=SecondWind node

# Certificate/key files are generated on first boot by sw-agent. The packaged
# systemd unit supplies their paths in the system state directory.

# Required to run the HTTP API server. Choose the bind address in image/config,
# not in Rust source. Development examples may use loopback; production should
# bind to the selected link interface once interface selection exists.
# SECONDWIND_AGENT_BIND=127.0.0.1:0
