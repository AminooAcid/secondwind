# SecondWind kiosk runtime config.
# Packaged node images install this as /etc/secondwind/sw-kiosk.env.

# Streaming client invocation (program name resolved on PATH). The kiosk
# passes the host address it learned from the agent at runtime.
SECONDWIND_STREAM_CLIENT=moonlight
SECONDWIND_STREAM_APP=Desktop

# Poll interval for the agent's kiosk state file, in milliseconds.
SECONDWIND_KIOSK_POLL_MS=500

# Development escape hatch: set to 1 to allow quitting the kiosk with `q`.
# Never enable in release images.
#SECONDWIND_KIOSK_ALLOW_EXIT=1
