[Unit]
Description=SecondWind data disk export (iSCSI target)
After=network-online.target secondwind-disk-provision.service
Wants=network-online.target
ConditionPathExists=/etc/secondwind/disk.env

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=/etc/secondwind/disk.env
ExecStart=/usr/local/lib/secondwind/secondwind-disk.sh up
ExecStop=/usr/local/lib/secondwind/secondwind-disk.sh down

[Install]
WantedBy=multi-user.target
