# SecondWind node agent — image runtime configuration.
# State/cert paths and the kiosk state file come from the systemd unit
# (StateDirectory/RuntimeDirectory); only image-level choices live here.

# Serve the API on an ephemeral port on all interfaces; mDNS advertises the
# real port. v0.1 relies on mTLS + pairing for access control; binding to
# the link interface only is tracked as a hardening follow-up in
# docs/DECISIONS.md.
SECONDWIND_AGENT_BIND=0.0.0.0:0

# Default display name shown during discovery/pairing (user-renamable later).
SECONDWIND_AGENT_NODE_NAME=SecondWind node

# Disk feature (v0.2): where first-boot provisioning writes the export
# identity, and which unit the agent starts/stops (via the polkit rule).
SECONDWIND_DISK_ENV_FILE=/etc/secondwind/disk.env
SECONDWIND_DISK_UNIT=secondwind-disk.service
