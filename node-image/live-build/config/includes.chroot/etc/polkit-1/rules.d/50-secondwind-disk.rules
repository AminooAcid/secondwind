// Allow the unprivileged SecondWind agent to start/stop exactly the units
// it orchestrates — nothing else.
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "secondwind") {
        var unit = action.lookup("unit");
        if (unit == "secondwind-disk.service" ||
            unit == "secondwind-share.service") {
            return polkit.Result.YES;
        }
    }
});
