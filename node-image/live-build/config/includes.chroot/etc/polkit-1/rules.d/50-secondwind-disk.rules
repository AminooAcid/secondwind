// Allow the unprivileged SecondWind agent to start/stop exactly the disk
// export unit — nothing else.
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") == "secondwind-disk.service" &&
        subject.user == "secondwind") {
        return polkit.Result.YES;
    }
});
